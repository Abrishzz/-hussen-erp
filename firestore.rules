rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Role from the user's /users doc (falls back to the custom claim, which the
    // emulator/admin seed sets). This lets roles be managed as data in production
    // without requiring Admin custom-claim writes.
    function docRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function hasRole(role) {
      return isAuthenticated() && (request.auth.token.role == role || docRole() == role);
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isCashier() {
      return hasRole('cashier');
    }

    function isStaff() {
      return hasRole('staff');
    }

    function isManager() {
      return hasRole('manager');
    }

    // A user can read their own /users doc (needed for client-side role
    // resolution). Writes are owner-only (via the top-level rule).
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
    }

    // Owner has full access to everything
    match /{document=**} {
      allow read, write: if isOwner();
    }

    // === SALES COLLECTION ===
    match /sales/{saleId} {
      // Cashier: read/write own sales; read all products
      allow read: if isCashier();
      allow create: if isCashier() && request.resource.data.cashierId == request.auth.uid;
      allow update: if isCashier() && resource.data.cashierId == request.auth.uid;
      allow delete: if false; // Only owner can delete via their own rules

      // Staff: read only (to see production demand)
      allow read: if isStaff();
      // Manager: read all branch sales (for cash confirmation)
      allow read: if isManager();
    }

    // === BRANCHES COLLECTION ===
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      // Owner manages branches (create/rename/deactivate); manager can read.
      // Owner writes are already granted by the top-level rule.
    }

    // === WAREHOUSE STOCK (central pool) ===
    match /warehouseStock/{productId} {
      allow read: if isAuthenticated();
      // Manager confirms/distributes; cashier returns unsold stock at cash close.
      allow write: if isManager() || isCashier();
    }

    // === BRANCH STOCK (received per branch) ===
    match /branchStock/{stockId} {
      allow read: if isAuthenticated();
      // Manager distributes/returns; cashier deducts on sale.
      allow write: if isManager() || isCashier();
    }

    // === DISTRIBUTIONS ===
    match /distributions/{distId} {
      allow read: if isManager() || isCashier() || isStaff();
      allow create: if isManager();
    }

    // === CASH CLOSES ===
    match /cashCloses/{closeId} {
      allow read: if isManager() || isCashier();
      allow create: if isCashier();
      allow update: if isManager(); // confirm receipt
    }

    // === PRODUCTS COLLECTION ===
    match /products/{productId} {
      // Cashier & Staff: read only
      allow read: if isCashier() || isStaff();
      // Owner: full access (already covered by top-level rule)
    }

    // === RAW MATERIALS COLLECTION ===
    match /rawMaterials/{materialId} {
      allow read: if isStaff() || isCashier();
      // Write: staff can update stock, owner full
      allow create, update: if isStaff();
    }

    // === STOCK MOVEMENTS COLLECTION ===
    match /stockMovements/{movId} {
      allow read: if isStaff() || isCashier();
      allow create: if isStaff();
      allow update: if isStaff();
    }

    // === SUPPLIERS COLLECTION ===
    match /suppliers/{supplierId} {
      allow read: if isStaff() || isCashier();
      allow write: if isStaff();
    }

    // === RECIPES COLLECTION ===
    match /recipes/{recipeId} {
      allow read: if isStaff() || isCashier();
      allow write: if isStaff();
    }

    // === PRODUCTION BATCHES COLLECTION ===
    match /productionBatches/{batchId} {
      allow read: if isStaff() || isCashier() || isManager();
      allow create, update: if isStaff();
      allow update: if isManager(); // manager confirms produced quantity
    }

    // === FINISHED GOODS COLLECTION ===
    match /finishedGoods/{productId} {
      allow read: if isStaff() || isCashier();
      allow write: if isStaff();
    }

    // === EMPLOYEES COLLECTION ===
    match /employees/{empId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }

    // === ATTENDANCE COLLECTION ===
    match /attendance/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }

    // === EXPENSES COLLECTION ===
    match /expenses/{expId} {
      allow read: if isOwner();
      allow write: if isOwner();
    }

    // === PAYROLL COLLECTION ===
    match /payroll/{payId} {
      allow read: if isOwner();
      allow write: if isOwner();
    }

    // === SETTINGS COLLECTION ===
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isOwner();
    }
  }
}
